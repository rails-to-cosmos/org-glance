;;; build-fat.el --- concatenate org-glance into one file -*- lexical-binding: t; -*-

;; Build a single loadable `dist/org-glance.el' from the multi-directory
;; sources.  Correctness hinges on LOAD ORDER: a macro must be defined before the
;; files that use it, or the concatenation fails to byte-compile.  Rather than
;; hand-maintain a topological sort, we let the real loader compute it: `require'
;; org-glance, then emit the files in `load-history' order (dependencies always
;; load before their dependents).  Each file's `provide'/`require' is kept
;; verbatim -- an internal `(require 'org-glance-X)' is a no-op once the earlier
;; section's `(provide 'org-glance-X)' has run.

(let* ((root (file-truename (or (getenv "FAT_ROOT") default-directory)))
       (out (expand-file-name "dist/org-glance.el" root))
       (seen (make-hash-table :test 'equal))
       (pkg-requires
        (with-temp-buffer
          (insert-file-contents (expand-file-name "org-glance.el" root))
          (if (re-search-forward "^;; Package-Requires:.*$" nil t)
              (match-string 0)
            ";; Package-Requires: ((emacs \"29.1\"))"))))
  ;; Force org-glance to load from the working sources, not any copy Eask
  ;; installed under .eask (which would make `load-history' point there).  Keep
  ;; the external dependencies under .eask on the path.
  (setq load-path
        (seq-remove (lambda (p) (string-match-p "/\\.eask/.*/org-glance-[0-9]"
                                                (file-truename p)))
                    load-path))
  (dolist (dir '("src/view" "src/data" ""))
    (push (expand-file-name dir root) load-path))
  (require 'org-glance)
  (make-directory (expand-file-name "dist" root) t)
  (with-temp-file out
    (insert ";;; org-glance.el --- Org-glance, single-file build "
            "-*- lexical-binding: t; -*-\n"
            ";;\n"
            ";; GENERATED by `make fat' from the multi-directory sources.  Do not edit.\n"
            ";; Load it standalone: put its directory on `load-path', install the\n"
            ";; dependencies below, then (require 'org-glance).\n"
            pkg-requires "\n"
            ";;; Code:\n")
    (dolist (entry (reverse load-history))
      (let* ((f (car entry))
             ;; load-history may point at .elc; take the .el source.
             (src (and (stringp f)
                       (let ((el (if (string-suffix-p ".elc" f) (substring f 0 -1) f)))
                         (and (string-suffix-p ".el" el) (file-exists-p el)
                              (file-truename el))))))
        (when (and src
                   (string-prefix-p root src)
                   ;; only the working sources -- not installed/build copies
                   (not (string-match-p "/\\(\\.eask\\|dist\\|test\\|build\\)/" src))
                   (not (gethash src seen)))
          (puthash src t seen)
          (insert "\n\n;;;; ---- " (file-relative-name src root) " ----\n\n")
          (insert
           (with-temp-buffer
             (insert-file-contents src)
             ;; Drop the file's own `-*- lexical-binding -*-' cookie line; the
             ;; fat file's top-of-file cookie governs the whole buffer.
             (goto-char (point-min))
             (when (looking-at ".*lexical-binding.*")
               (delete-region (point) (min (point-max) (1+ (line-end-position)))))
             ;; Drop cross-file forward declarations of symbols that now live in
             ;; this same file -- redundant, and they warn as "defined multiple
             ;; times".  External `declare-function's (org, etc.) are kept.
             (goto-char (point-min))
             (while (re-search-forward
                     "^(declare-function \\(org-glance\\|table-view\\)[^\n]*\n" nil t)
               (replace-match ""))
             (buffer-string))))))
    (insert "\n\n(provide 'org-glance)\n;;; org-glance.el ends here\n"))
  (message "fat build: wrote %s (%d files)" out (hash-table-count seen)))

;;; build-fat.el ends here
